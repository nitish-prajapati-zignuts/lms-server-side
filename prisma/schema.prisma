generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id          String          @id @default(cuid())
  name        String
  email       String          @unique
  password    String
  createdAt   DateTime        @default(now())
  role        ROLE_BASED_USER @default(USER)
  updatedAt   DateTime        @updatedAt
  isDeleted   Boolean         @default(false)
  roles       UserRole[]
  sessions    Sessions[]
  enrollments Enrollment[]
}

model UserRole {
  id     String       @id @default(cuid())
  userId String
  roleId String
  user   Registration @relation(fields: [userId], references: [id])
  role   Role         @relation(fields: [roleId], references: [id])
}

model Permission {
  id        String           @id @default(cuid())
  action    String //create ,read,update,delete,manage 
  subject   String //dashboard,users,courses,permissions,enrollments 
  condition Json? //optional dynamic rules 
  roles     RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role?      @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([roleId, permissionId])
}

model Role {
  id          String           @id @default(cuid())
  role        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Sessions {
  id           String       @id @default(cuid())
  userId       String
  token        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  isDeleted    Boolean      @default(false)
  ipAddress    String?
  userAgent    String?
  os           String?
  registration Registration @relation(fields: [userId], references: [id])
}

model Course {
  id          String       @id @default(cuid())
  title       String?
  description String?
  image       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  isDeleted   Boolean      @default(false)
  duration    Int?
  enrollments Enrollment[]
  Module      Module[]
}

model Enrollment {
  id           String       @id @default(cuid())
  userId       String
  courseId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  isDeleted    Boolean      @default(false)
  course       Course       @relation(fields: [courseId], references: [id])
  registration Registration @relation(fields: [userId], references: [id])
}

model Module {
  id        String   @id
  courseId  String
  title     String?
  content   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
  isDeleted Boolean  @default(false)
  Course    Course   @relation(fields: [courseId], references: [id])
}

enum ROLE_BASED_USER {
  ADMIN
  USER
}
